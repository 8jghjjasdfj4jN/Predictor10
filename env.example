# Predictor10 — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Render-deployed envs are configured in the Render dashboard, not this file.

# ─── Required from day one ───────────────────────────────────────────────────

# Render Postgres connection string. Find it in Render dashboard →
# your database → "External Database URL" (for local dev) or "Internal
# Database URL" (for the deployed server, configured directly in Render).
# Connection strings include `?sslmode=require` — leave it in.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require

# football-data.org free tier API key.
# Register: https://www.football-data.org/client/register
FOOTBALL_API_KEY=

# ─── Required by Phase 2 step 2b (auth) ──────────────────────────────────────

# Used to HMAC-sign session cookies. Generate a new one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value forces all existing sessions to re-authenticate.
SESSION_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────

# "development" for verbose errors; "production" on Render.
NODE_ENV=development

# Express server port. Defaults to 3000.
PORT=3000

# "true" to log every Drizzle query. Very noisy — dev debugging only.
DB_LOG=false

# Dev-only: bypass the 7-day late-entry close (arch §4 / Decided Rule #8) so
# entry/predict flows can be tested mid-Round. NEVER set true in production.
# Anti-cheat per-match lock (Decided Rule #7) stays on regardless.
BYPASS_LATE_ENTRY=false

# ─── Deferred (pre-launch wiring) ────────────────────────────────────────────
# Resend integration lands right before launch — not needed in dev for now.
# RESEND_API_KEY=
# RESEND_FROM=
